    "typesense:index": "npx dotenv -e .env.local -- node scripts/ingest/index_assembly_optimized.js",
    "typesense:index-test": "npx dotenv -e .env.local -- node scripts/ingest/index_assembly_optimized.js --limit 100",
    "verify": "npx dotenv -e .env.local -- node scripts/verify-setup.js"
